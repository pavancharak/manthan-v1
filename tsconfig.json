{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "dist",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}