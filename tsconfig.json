{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "apps/core-server/**/*.ts",
    "core/**/*.ts",
    "execution/**/*.ts",
    "rules/**/*.ts",
    "schema/**/*.json"
  ],
  "exclude": ["node_modules", "dist"]
}