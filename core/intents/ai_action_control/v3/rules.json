{
  "rule_version": "v3",
  "rules": [
    {
      "id": "block-high-risk-no-guardrails",
      "group": 1,
      "order": 1,
      "outcome": "BLOCK",
      "condition": {
        "field": "risk_level",
        "operator": "eq",
        "value": "high"
      },
      "actions": []
    },
    {
      "id": "escalate-medium-risk",
      "group": 2,
      "order": 1,
      "outcome": "ESCALATE",
      "condition": {
        "field": "risk_level",
        "operator": "eq",
        "value": "medium"
      },
      "actions": [
        "require_human_review"
      ]
    },
    {
      "id": "guardrails-enforced",
      "group": 3,
      "order": 1,
      "outcome": "ESCALATE",
      "condition": {
        "field": "has_guardrails",
        "operator": "eq",
        "value": true
      },
      "actions": [
        "require_human_review"
      ]
    },
    {
      "id": "allow-safe-actions",
      "group": 4,
      "order": 1,
      "outcome": "ALLOW",
      "condition": {
        "field": "risk_level",
        "operator": "eq",
        "value": "low"
      },
      "actions": [
        "execute_ai_action"
      ]
    }
  ]
}